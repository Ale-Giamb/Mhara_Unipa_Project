Passo 6: content='\n                Nome: Alessandro\n                Cognome: Rossi\n                Peso: 70 kg\n                Altezza: 1.8 m\n                Test Mobilità: Mobilità Alta, Data: 2025-01-01, punteggio: 9\n                Test Nutrizionale: MUST, Data: 2026-01-23, punteggio: 0\n                Stato Cognitivo: Ottimo\n                Test Cognitivo: Punteggio 15 (Data: 2026-01-23)\n                Trattamento Passato: intervento al ginocchio (ID: T001)\n                Terapia Fisica: Generica\n                Parametri Ematici: Glicemia 90, Emoglobina 14.0\n                Stato Nutrizionale: Ben Nutrito\n                Patologie: None - None\n                Intolleranze: None - None\n                Parametri Vitali: Pressione 120/80, Battito 72, Temperatura 36.5°C\n                ' name='Information' id='d2b90d02-51cf-4a62-9084-db8e6ac2b8a5' tool_call_id='call_ECuQ5dz3Xc63Zac5M1kQ84mP'

